	measure 'QA Daily' =
			
			SWITCH (
			    SELECTEDVALUE ( 'Dim Metric'[Metric] ),
			    "Dwell Time",             [Dwell Time (Daily)],
			    "Ext Signals",            [Ext Signals (Daily)],
			    "Ext Signals 2",          [Ext Signals 2 (Daily)],
			    "Eye Contacts",           [Eye Contacts (Daily)],
			    "Eye Contacts Weighted",  [Eye Contacts Weighted (Daily)],
			    "Impressions Weighted",   [Impressions Weighted (Daily)],
			    "Impressions Weighted 2", [Impressions Weighted 2 (Daily)],
			    "Signals",                [Signals (Daily)],
			    "EXTRAPOLATED_NUMBER_OF_USERS",        [PaS],
			    "EXTRAPOLATED_USERS_2",                [Total Population],
			    "EXTRAPOLATED_NUMBER_OF_EYE_CONTACTS", [OTS],
			    "Users",                  [Users (Daily)]
			)
		displayFolder: Footfall QA
		lineageTag: 168466f6-07d5-4748-a8f3-8a901997e83c

		formatStringDefinition =
				IF (
				    SELECTEDVALUE ( 'Dim Metric'[Metric] ) = "Dwell Time",
				    "0.0%",
				    "#,##0"
				)

	measure 'QA Hourly' =
			
			SWITCH (
			    SELECTEDVALUE ( 'Dim Metric'[Metric] ),
			    "Dwell Time",             [Dwell Time (Hourly avg)],
			    "Ext Signals",            [Ext Signals (Hourly)],
			    "Ext Signals 2",          [Ext Signals 2 (Hourly)],
			    "Eye Contacts",           [Eye Contacts (Hourly)],
			    "Eye Contacts Weighted",  [Eye Contacts Weighted (Hourly)],
			    "Impressions Weighted",   [Impressions Weighted (Hourly)],
			    "Impressions Weighted 2", [Impressions Weighted 2 (Hourly)],
			    "Signals",                [Signals (Hourly)],
			    "EXTRAPOLATED_NUMBER_OF_USERS",        [PaS (Hourly)],
			    "EXTRAPOLATED_USERS_2",                [Total Population (Hourly)],
			    "EXTRAPOLATED_NUMBER_OF_EYE_CONTACTS", [OTS (Hourly)],
			    "Users",                  [Users (Hourly)]
			)
		displayFolder: Footfall QA
		lineageTag: a08ce8fc-3041-4729-a0b6-83e1187d622e

		formatStringDefinition =
