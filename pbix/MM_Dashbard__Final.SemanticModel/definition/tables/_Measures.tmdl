	measure 'Header Title' =
			
			VAR NSites  = DISTINCTCOUNT ( Master_Sites[MM ID] )
			VAR YM      = VALUES ( Footfall[YEAR_MONTH] )
			VAR Cnt     = COUNTROWS ( YM )
			VAR MinYM   = MINX ( YM, Footfall[YEAR_MONTH] )
			VAR MaxYM   = MAXX ( YM, Footfall[YEAR_MONTH] )
			VAR MinDate = DATE ( VALUE ( LEFT ( MinYM, 4 ) ), VALUE ( RIGHT ( MinYM, 2 ) ), 1 )
			VAR MaxDate = DATE ( VALUE ( LEFT ( MaxYM, 4 ) ), VALUE ( RIGHT ( MaxYM, 2 ) ), 1 )
			VAR Period =
			    SWITCH (
			        TRUE (),
			        Cnt = 0, "No period",
			        Cnt = 1, FORMAT ( MinDate, "MMMM YYYY" ),
			        FORMAT ( MinDate, "MMM YYYY" ) & " – " & FORMAT ( MaxDate, "MMM YYYY" )
			    )
			VAR SitesTxt = FORMAT ( NSites, "0" ) & " " & IF ( NSites = 1, "site", "sites" )
			RETURN
			    SitesTxt & " · " & Period
		displayFolder: Titles
		lineageTag: bb547881-aa04-4ec7-9831-ea4d67d39bfc

