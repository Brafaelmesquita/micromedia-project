		lineageTag: 463447a4-0685-44ff-82bd-22e34d7f37d5

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Visitation Audience' =
			
			CALCULATE ( SUM ( Footfall[EXTRAPOLATED_USERS_2] ),
			    Footfall[MOVEMENT_MODALITY] = "All",
			    Footfall[HOUR] <> 25 )
		formatString: #,0
		displayFolder: Modality
		lineageTag: 5924e282-4869-42b4-9fde-703272e8af4c

	measure 'Movement Audience' =
			
			CALCULATE ( SUM ( Footfall[EXTRAPOLATED_USERS_2] ),
			    Footfall[VISITATION_MODALITY] = "All",
			    Footfall[HOUR] <> 25 )
		displayFolder: Modality
		lineageTag: fef4d227-56f4-4c0d-abc2-2ac8819dfd05

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Avg Brand Affinity Index' = AVERAGE ( Brand_Affinity[BRAND_AFFINITY_INDEX] )
		displayFolder: Modality
		lineageTag: 898bba54-e4fd-49fb-b214-88a566d2c748

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Class Audience (Hourly)' =
			
			SUMX (
			    FILTER (
			        Demographics_ClassLong,
			        Demographics_ClassLong[MOVEMENT_MODALITY] = "All"
			            && Demographics_ClassLong[HasValidSite] = TRUE ()
			    ),
			    VAR _code = Demographics_ClassLong[CODE]
			    VAR _ym   = Demographics_ClassLong[YEAR_MONTH_KEY]
			    VAR _hr   = Demographics_ClassLong[HOUR]
			    RETURN
			        ( Demographics_ClassLong[REACH_PCT] / 100 )
			        * CALCULATE (
			            SUM ( Footfall[EXTRAPOLATED_USERS_2] ),
			            Footfall[CODE] = _code,
			            Footfall[YEAR_MONTH] = _ym,
			            Footfall[HOUR] = _hr,
			            Footfall[IS_GRAND_TOTAL] = 1,
			            Footfall[HasValidSite] = TRUE ()
			        )
			)
		formatString: #,0
		lineageTag: 53db95ee-a94a-4c8d-a009-67aa3fc03265

	measure 'Class %' =
			
			DIVIDE (
			    [Class Audience (Hourly)],
			    CALCULATE ( [Class Audience (Hourly)], REMOVEFILTERS ( Demographics_ClassLong[SEGMENT] ) )
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 174514e5-9912-45ee-9ad7-307624207525

	measure 'Class Title' = "Audience by " & LOWER ( SELECTEDVALUE ( Demographics_ClassLong[BREAKDOWN], "class" ) )
		displayFolder: Titles
		lineageTag: e2472f7f-4e3c-4a6d-a4e0-0976b277fb94

	measure 'Site Header' =
			
			VAR SiteName = SELECTEDVALUE ( Master_Sites[Display Name] )
			VAR SiteID   = SELECTEDVALUE ( Master_Sites[MM ID] )
			RETURN
			    IF (
			        ISBLANK ( SiteName ),
			        "Multiple sites",
			        SiteName & " - MM ID " & SiteID
			    )
		displayFolder: Titles
		lineageTag: 27445238-20cc-42d9-9371-4af099f2895e

	measure 'Exposure Ratio' = DIVIDE( [OTS], [PaS] )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Footfall QA
		lineageTag: b0700bd0-2797-4899-a865-57e5321da44b

	measure 'Total Screens' =
			
			CALCULATE(
			    DISTINCTCOUNT( Footfall[CODE] ),
			    Footfall[IS_GRAND_TOTAL] = 1,
			    Footfall[HOUR] = 25
			)
		formatString: 0
		displayFolder: Footfall QA
		lineageTag: d9851998-dd38-4840-9d19-b8dc0159d1ae

	measure 'Median Exposure (screen)' = MEDIANX( VALUES( Footfall[CODE] ), [Exposure Ratio] )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Footfall QA
		lineageTag: 77182f5f-075d-4f37-a346-55312b554872

	measure 'P25 Exposure' = PERCENTILEX.INC( VALUES( Footfall[CODE] ), [Exposure Ratio], 0.25 )
