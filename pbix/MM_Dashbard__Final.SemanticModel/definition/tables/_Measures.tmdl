	measure 'Class % Check (per cell)' =
			-- [Diagnostics]
			AVERAGEX (
			    SUMMARIZE (
			        FILTER ( Demographics_ClassLong, Demographics_ClassLong[MOVEMENT_MODALITY] = "All" ),
			        Demographics_ClassLong[CODE],
			        Demographics_ClassLong[YEAR_MONTH],
			        Demographics_ClassLong[HOUR],
			        Demographics_ClassLong[BREAKDOWN]
			    ),
			    CALCULATE ( SUM ( Demographics_ClassLong[REACH_PCT] ) )
			)
		displayFolder: Professions
