table _Measures
	lineageTag: 6dd560a5-b5c9-4b14-94bc-58d1b69adb09

	measure PaS =
			
			CALCULATE(
			    SUM( Footfall[EXTRAPOLATED_NUMBER_OF_USERS] ),
			    Footfall[IS_GRAND_TOTAL] = 1,
			    Footfall[HOUR] = 25,
			    Footfall[HasValidSite] = TRUE()
			)
		formatString: #,0
		displayFolder: KPIs\Base
		lineageTag: fff3dce4-db9e-4175-8f3e-6e72c06ddeec

