	measure 'Age Audience (Hourly)' =
			
			SUMX (
			    FILTER ( Demographics_AgeLong, Demographics_AgeLong[MOVEMENT_MODALITY] = "All" ),
			    VAR _code = Demographics_AgeLong[CODE]
			    VAR _ym   = Demographics_AgeLong[YEAR_MONTH]
			    VAR _hr   = Demographics_AgeLong[HOUR]
			    VAR _pct  = DIVIDE ( Demographics_AgeLong[REACH_PCT], 100 )
			    RETURN
			        _pct *
			        CALCULATE (
			            SUM ( Footfall[EXTRAPOLATED_USERS_2] ),
			            Footfall[CODE]           = _code,
			            Footfall[YEAR_MONTH]     = _ym,
			            Footfall[HOUR]           = _hr,
			            Footfall[IS_GRAND_TOTAL] = 1,
			            Footfall[HasValidSite] = TRUE ()
			        )
			)
		formatString: #,0
		displayFolder: Age&Gender
		lineageTag: 459ed597-c6d9-46ed-b469-e907371fd71f

	measure 'Age Impressions (OTS)' =
			
			SUMX (
			    FILTER ( Demographics_AgeLong, Demographics_AgeLong[MOVEMENT_MODALITY] = "All" ),
			    VAR _code = Demographics_AgeLong[CODE]
			    VAR _ym   = Demographics_AgeLong[YEAR_MONTH]
			    VAR _hr   = Demographics_AgeLong[HOUR]
			    VAR _pct  = DIVIDE ( Demographics_AgeLong[REACH_PCT], 100 )
			    RETURN
			        _pct *
			        CALCULATE (
			            SUM ( Footfall[EXTRAPOLATED_NUMBER_OF_EYE_CONTACTS_WEIGHTED] ),
			            Footfall[CODE]           = _code,
			            Footfall[YEAR_MONTH]     = _ym,
			            Footfall[HOUR]           = _hr,
			            Footfall[IS_GRAND_TOTAL] = 1
			        )
			)
		displayFolder: Age&Gender
		lineageTag: d5f2aefe-0bbe-4ef0-9227-52b1e969de5e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Population (Inflation)' = DIVIDE ( [Total Population (Hourly)], [Total Population] )
